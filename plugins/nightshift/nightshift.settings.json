{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Nightshift full-auto posture. Copy the 'permissions' block into your project's .claude/settings.json (or ~/.claude/settings.json). The plugin's PreToolUse guard (guard.py) is the real safety net for destructive ops; these deny rules are defence-in-depth. 'allow' auto-approves create/alter work so runs proceed unattended.",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Task",
      "TodoWrite",
      "WebSearch",
      "WebFetch",
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(node:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pytest:*)",
      "Bash(go:*)",
      "Bash(cargo:*)",
      "Bash(make:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout -b:*)",
      "Bash(git switch:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git push:*)",
      "Bash(gh issue:*)",
      "Bash(gh pr:*)",
      "Bash(gh repo view:*)",
      "Bash(cursor-agent:*)",
      "Bash(codex:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(sudo:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(mkfs:*)",
      "Bash(dd:*)",
      "Bash(terraform destroy:*)",
      "Write(.env)",
      "Write(.env.*)",
      "Edit(.env)"
    ]
  }
}
